{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "مجله‌ای",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "background", "color": "#ffffff", "name": "Background" },
				{ "slug": "foreground", "color": "#111111", "name": "Foreground" },
				{ "slug": "primary", "color": "#dc2626", "name": "Primary" },
				{ "slug": "primary-foreground", "color": "#ffffff", "name": "Primary foreground" },
				{ "slug": "secondary", "color": "#1e293b", "name": "Secondary" },
				{ "slug": "accent", "color": "#eab308", "name": "Accent" },
				{ "slug": "muted", "color": "#f5f5f5", "name": "Muted" },
				{ "slug": "muted-foreground", "color": "#737373", "name": "Muted foreground" },
				{ "slug": "border", "color": "#d4d4d4", "name": "Border" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--serif)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system)",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--primary-foreground)"
				},
				"border": {
					"radius": "0"
				}
			}
		}
	}
}
