{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "مینیمال",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "background", "color": "#ffffff", "name": "Background" },
				{ "slug": "foreground", "color": "#18181b", "name": "Foreground" },
				{ "slug": "primary", "color": "#18181b", "name": "Primary" },
				{ "slug": "primary-foreground", "color": "#ffffff", "name": "Primary foreground" },
				{ "slug": "secondary", "color": "#52525b", "name": "Secondary" },
				{ "slug": "accent", "color": "#71717a", "name": "Accent" },
				{ "slug": "muted", "color": "#f4f4f5", "name": "Muted" },
				{ "slug": "muted-foreground", "color": "#a1a1aa", "name": "Muted foreground" },
				{ "slug": "border", "color": "#e4e4e7", "name": "Border" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "0"
				}
			}
		}
	}
}
