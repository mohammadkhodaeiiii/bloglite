{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "680px",
			"wideSize": "1100px"
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"custom": true,
			"customGradient": true,
			"customDuotone": true,
			"palette": [
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "پس‌زمینه"
				},
				{
					"slug": "foreground",
					"color": "#1a1a2e",
					"name": "متن"
				},
				{
					"slug": "primary",
					"color": "#1a56db",
					"name": "اصلی"
				},
				{
					"slug": "primary-foreground",
					"color": "#ffffff",
					"name": "متن روی اصلی"
				},
				{
					"slug": "secondary",
					"color": "#6366f1",
					"name": "ثانویه"
				},
				{
					"slug": "accent",
					"color": "#f97316",
					"name": "تأکید"
				},
				{
					"slug": "muted",
					"color": "#f8fafc",
					"name": "ملایم"
				},
				{
					"slug": "muted-foreground",
					"color": "#64748b",
					"name": "متن ملایم"
				},
				{
					"slug": "border",
					"color": "#e2e8f0",
					"name": "حاشیه"
				}
			],
			"gradients": [
				{
					"slug": "primary-to-secondary",
					"gradient": "linear-gradient(135deg, #1a56db 0%, #6366f1 100%)",
					"name": "اصلی به ثانویه"
				},
				{
					"slug": "subtle-light",
					"gradient": "linear-gradient(180deg, #f8fafc 0%, #ffffff 100%)",
					"name": "روشن ملایم"
				},
				{
					"slug": "warm-accent",
					"gradient": "linear-gradient(135deg, #f97316 0%, #ef4444 100%)",
					"name": "تأکید گرم"
				}
			],
			"duotone": [
				{
					"slug": "primary-duotone",
					"colors": [ "#1a1a2e", "#1a56db" ],
					"name": "دوتون اصلی"
				},
				{
					"slug": "grayscale",
					"colors": [ "#000000", "#ffffff" ],
					"name": "خاکستری"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"customFontSize": true,
			"lineHeight": true,
			"dropCap": false,
			"writingMode": true,
			"fontFamilies": [
				{
					"slug": "system",
					"name": "سیستمی",
					"fontFamily": "\"Vazirmatn\", \"IRANSans\", \"IRANYekan\", \"Tahoma\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", Arial, sans-serif"
				},
				{
					"slug": "serif",
					"name": "سریف",
					"fontFamily": "\"Vazirmatn\", \"IRANSans\", Charter, \"Bitstream Charter\", \"Sitka Text\", Cambria, Georgia, \"Times New Roman\", serif"
				},
				{
					"slug": "monospace",
					"name": "تک‌فاصله",
					"fontFamily": "ui-monospace, SFMono-Regular, \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "کوچک",
					"size": "0.875rem",
					"fluid": false
				},
				{
					"slug": "medium",
					"name": "متوسط",
					"size": "1.0625rem",
					"fluid": false
				},
				{
					"slug": "large",
					"name": "بزرگ",
					"size": "1.25rem",
					"fluid": {
						"min": "1.125rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "x-large",
					"name": "خیلی بزرگ",
					"size": "1.875rem",
					"fluid": {
						"min": "1.5rem",
						"max": "1.875rem"
					}
				},
				{
					"slug": "xx-large",
					"name": "عظیم",
					"size": "2.75rem",
					"fluid": {
						"min": "2rem",
						"max": "2.75rem"
					}
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"customSpacingSize": true,
			"units": [ "px", "em", "rem", "%", "vw", "vh" ],
			"padding": true,
			"margin": true,
			"blockGap": true,
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"slug": "20",
					"name": "1",
					"size": "0.5rem"
				},
				{
					"slug": "30",
					"name": "2",
					"size": "1rem"
				},
				{
					"slug": "40",
					"name": "3",
					"size": "1.5rem"
				},
				{
					"slug": "50",
					"name": "4",
					"size": "2.5rem"
				},
				{
					"slug": "60",
					"name": "5",
					"size": "4rem"
				},
				{
					"slug": "70",
					"name": "6",
					"size": "6rem"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"slug": "small",
					"name": "کوچک",
					"shadow": "0 1px 2px 0 rgba(26, 26, 46, 0.06)"
				},
				{
					"slug": "medium",
					"name": "متوسط",
					"shadow": "0 4px 12px -2px rgba(26, 26, 46, 0.1)"
				},
				{
					"slug": "large",
					"name": "بزرگ",
					"shadow": "0 12px 28px -6px rgba(26, 26, 46, 0.14)"
				}
			]
		},
		"dimensions": {
			"minHeight": true,
			"aspectRatio": true
		},
		"position": {
			"sticky": true
		},
		"custom": {
			"radius": {
				"small": "0.375rem",
				"medium": "0.75rem",
				"large": "1.25rem"
			},
			"reading": {
				"lineHeight": "1.8",
				"paragraphSpacing": "1.5em"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--40)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--30)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--30)"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2px"
					}
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "700",
					"lineHeight": "1.3"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--primary-foreground)"
				},
				"border": {
					"radius": "var(--wp--custom--radius--medium)"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"right": "1.5rem",
						"bottom": "0.75rem",
						"left": "1.5rem"
					}
				},
				"typography": {
					"fontWeight": "600"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--secondary)"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--foreground)",
						"style": "solid",
						"width": "2px"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--muted-foreground)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--foreground)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "500"
				}
			},
			"core/post-content": {
				"typography": {
					"lineHeight": "var(--wp--custom--reading--line-height, 1.8)"
				}
			},
			"core/pullquote": {
				"border": {
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--border)"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"width": "4px",
						"style": "solid",
						"color": "var(--wp--preset--color--primary)"
					}
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--30)"
					}
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--muted)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--monospace)"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--30)"
					}
				},
				"border": {
					"radius": "var(--wp--custom--radius--small)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "سربرگ",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "پاورقی",
			"area": "footer"
		},
		{
			"name": "sidebar",
			"title": "نوار کناری",
			"area": "uncategorized"
		},
		{
			"name": "post-meta",
			"title": "اطلاعات نوشته",
			"area": "uncategorized"
		},
		{
			"name": "breadcrumb",
			"title": "مسیر راهنما",
			"area": "uncategorized"
		},
		{
			"name": "comments",
			"title": "دیدگاه‌ها",
			"area": "uncategorized"
		}
	]
}
